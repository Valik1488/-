@page "/login"
@using MusicApp.Client.Interfaces
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<MudContainer Class="mt-4" MaxWidth="MaxWidth.ExtraLarge">
    <MudPaper Elevation="3" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #1DB954 0%, #191414 100%);">
        <MudText Typo="Typo.h3" Class="mb-2" Style="color: white; font-weight: 700;">Підключення до Spotify</MudText>
        <MudText Typo="Typo.subtitle1" Style="color: white; opacity: 0.8;">Увійдіть, щоб отримати доступ до всіх можливостей застосунку</MudText>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="8" lg="6" Class="mx-auto">
            <MudCard Elevation="3" Class="pa-6">
                <MudCardContent>
                    <div class="d-flex flex-column align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Success" Style="font-size: 64px; margin-bottom: 16px;" />
                        <MudText Typo="Typo.h5" Align="Align.Center">Увійдіть у свій обліковий запис Spotify</MudText>
                        <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">
                            Підключіть свій обліковий запис Spotify, щоб переглядати музику, відкривати нових виконавців та інше.
                        </MudText>
                    </div>

                    @if (isLoading)
                    {
                        <div class="d-flex justify-center my-4">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                        </div>
                        <MudText Align="Align.Center">Підготовка входу...</MudText>
                    }
                    else if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Class="my-4" Variant="Variant.Filled">@errorMessage</MudAlert>
                        <div class="d-flex justify-center mt-4">
                            <MudButton Variant="Variant.Filled"
                                      Color="Color.Primary"
                                      OnClick="RetryLogin"
                                      StartIcon="@Icons.Material.Filled.Refresh">
                                Спробувати ще раз
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center">
                            <MudButton Variant="Variant.Filled"
                                      Color="Color.Success"
                                      StartIcon="@Icons.Material.Filled.MusicNote"
                                      Size="Size.Large"
                                      Style="padding: 12px 24px;"
                                      OnClick="LoginWithSpotify">
                                Підключитися до Spotify
                            </MudButton>
                        </div>
                    }
                </MudCardContent>

                <MudDivider Class="my-4" />

                <MudCardActions>
                    <MudButton Variant="Variant.Text"
                              Color="Color.Default"
                              Href="/"
                              StartIcon="@Icons.Material.Filled.ArrowBack">
                        Назад на головну
                    </MudButton>
                </MudCardActions>
            </MudCard>

            <MudPaper Elevation="0" Class="mt-6 pa-4" Style="background-color: rgba(29, 185, 84, 0.1); border-radius: 4px;">
                <MudText Typo="Typo.subtitle2" Style="color: #1DB954;">
                    <span class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" />
                        Підключаючись, Ви надаєте цьому застосунку доступ до Ваших даних Spotify відповідно до нашої політики конфіденційності.
                    </span>
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool isLoading = false;
    private string errorMessage = "";

    private async Task LoginWithSpotify()
    {
        try
        {
            isLoading = true;
            var loginUrl = await AuthService.GetSpotifyLoginUrlAsync();

            NavigationManager.NavigateTo(loginUrl);
        }
        catch (Exception ex)
        {
            errorMessage = $"Не вдалося розпочати процес входу: {ex.Message}";
            Console.WriteLine($"Помилка входу: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void RetryLogin()
    {
        errorMessage = "";
    }
}
