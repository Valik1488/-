@page "/auth/spotify-success"
@using MusicApp.Client.Interfaces
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<MudContainer Class="mt-4" MaxWidth="MaxWidth.ExtraLarge">
    <MudPaper Elevation="3" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #1DB954 0%, #191414 100%);">
        <MudText Typo="Typo.h3" Class="mb-2" Style="color: white; font-weight: 700;">Статус автентифікації</MudText>
        <MudText Typo="Typo.subtitle1" Style="color: white; opacity: 0.8;">Обробка підключення до Spotify</MudText>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="8" lg="6" Class="mx-auto">
            <MudCard Elevation="3" Class="pa-6">
                <MudCardContent>
                    <div class="d-flex flex-column align-center">
                        @if (loading)
                        {
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
                            <MudText Typo="Typo.h5" Align="Align.Center">Обробка автентифікації</MudText>
                            <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">
                                Будь ласка, зачекайте, поки ми підключаємо Ваш обліковий запис Spotify...
                            </MudText>
                        }
                        else if (error)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Style="font-size: 64px; margin-bottom: 16px;" />
                            <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Error">Помилка автентифікації</MudText>
                            <MudAlert Severity="Severity.Error" Class="my-4" Variant="Variant.Filled">@errorMessage</MudAlert>
                            <div class="d-flex mt-4">
                                <MudButton Variant="Variant.Filled"
                                          Color="Color.Primary"
                                          Href="/login"
                                          StartIcon="@Icons.Material.Filled.Refresh"
                                          Class="mx-2">
                                    Спробувати ще раз
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                          Color="Color.Default"
                                          Href="/"
                                          StartIcon="@Icons.Material.Filled.Home"
                                          Class="mx-2">
                                    Повернутися на головну
                                </MudButton>
                            </div>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 64px; margin-bottom: 16px;" />
                            <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Success">Автентифікація успішна!</MudText>
                            <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2 mb-4">
                                Ви успішно підключили свій обліковий запис Spotify. Тепер ви можете користуватися всіма можливостями застосунку.
                            </MudText>

                            <MudCard Elevation="1" Class="mt-4 mb-6 pa-4" Style="width: 100%; background-color: rgba(29, 185, 84, 0.1);">
                                <MudText Typo="Typo.subtitle1" Style="color: #1DB954;" Class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" />
                                    Що б Ви хотіли зробити далі?
                                </MudText>
                            </MudCard>

                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudButton Variant="Variant.Filled"
                                              Color="Color.Primary"
                                              FullWidth="true"
                                              Href="/"
                                              StartIcon="@Icons.Material.Filled.Home">
                                        Перейти до панелі керування
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudButton Variant="Variant.Outlined"
                                              Color="Color.Primary"
                                              FullWidth="true"
                                              Href="/profile"
                                              StartIcon="@Icons.Material.Filled.Person">
                                        Переглянути профіль
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudButton Variant="Variant.Outlined"
                                              Color="Color.Primary"
                                              FullWidth="true"
                                              Href="/playlists"
                                              StartIcon="@Icons.Material.Filled.LibraryMusic">
                                        Переглянути плейлисти
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudButton Variant="Variant.Outlined"
                                              Color="Color.Primary"
                                              FullWidth="true"
                                              Href="/artists/search"
                                              StartIcon="@Icons.Material.Filled.Search">
                                        Знайти виконавців
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool loading = true;
    private bool error = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
            var queryParams = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var token = queryParams["token"];

            Console.WriteLine($"Отримано токен з URL: {token?.Substring(0, 10)}...");

            if (string.IsNullOrEmpty(token))
            {
                error = true;
                errorMessage = "Токен автентифікації не отримано.";
                return;
            }

            var success = await AuthService.HandleSpotifyCallbackAsync(token);
            if (!success)
            {
                error = true;
                errorMessage = "Не вдалося обробити токен автентифікації.";
                return;
            }

            var isAuthenticated = await AuthService.IsUserAuthenticated();
            Console.WriteLine($"Перевірка IsUserAuthenticated повернула: {isAuthenticated}");

            loading = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Помилка у callback: {ex.Message}");
            error = true;
            errorMessage = $"Помилка: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }
}
